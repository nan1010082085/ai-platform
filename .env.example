# AI Platform Docker Compose Environment
# Copy this file to .env and fill in your values
# Usage: docker compose -f docker-compose.ai.yml up -d

# === Required ===

# LLM API key (at least one provider)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=

# === Optional -- LLM Providers ===

# DeepSeek
# DEEPSEEK_BASE_URL=
# DEEPSEEK_MODEL=

# OpenAI (alternative)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=

# Anthropic (alternative)
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=
# CLAUDE_MODEL=

# Mimo (alternative)
# MIMO_API_KEY=
# MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
# MIMO_MODEL=mimo-v2.5

# Default provider (deepseek | openai | anthropic | mimo)
# DEFAULT_LLM=

# Set to false to use only DB-stored ModelConfig
# PLATFORM_LLM_ENABLED=true

# === Optional -- Embedding (RAG) ===

# SiliconFlow BGE-M3 (free, recommended for Chinese)
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.hpc-ai.com/inference/v1
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DIMENSIONS=1024

# === Optional -- Server ===

# CREDENTIAL_SECRET=
# CORS_ORIGINS=http://localhost:5300

# === Optional -- AI Behavior ===

# AI_ENABLE_TASK_PLANNER=true
